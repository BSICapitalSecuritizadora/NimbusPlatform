APP_NAME=Laravel
# SECURITY: Set to 'production' in production — enables HSTS, secure cookies, and tighter error handling
APP_ENV=local
# SECURITY: Generate with 'php artisan key:generate'. Never share or commit the real value
APP_KEY=
# SECURITY: Must be false in production to avoid leaking stack traces
APP_DEBUG=true
APP_URL=http://localhost
# SECURITY: Set to * on Azure App Service; use specific IP/CIDR ranges for other reverse proxies
TRUSTED_PROXIES=127.0.0.1,::1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# SECURITY: Encrypt session payload at rest (recommended for production)
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SECURITY: Set to true in production (requires HTTPS). Controlled via APP_ENV when not set explicitly
SESSION_SECURE_COOKIE=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_TIMEOUT=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

PROPOSAL_MAILER=log
PROPOSAL_MAIL_FROM_ADDRESS="${MAIL_FROM_ADDRESS}"
PROPOSAL_MAIL_FROM_NAME="${MAIL_FROM_NAME}"
PROPOSAL_CONTINUATION_EXPIRES_DAYS=7
PROPOSAL_CONTINUATION_CODE_LENGTH=6

NIMBUS_MAILER="${MAIL_MAILER}"
NIMBUS_MAIL_FROM_ADDRESS="${MAIL_FROM_ADDRESS}"
NIMBUS_MAIL_FROM_NAME="${MAIL_FROM_NAME}"
NIMBUS_ACCESS_TOKEN_EXPIRES_DAYS=7

OUTLOOK_MAIL_HOST=smtp.office365.com
OUTLOOK_MAIL_PORT=587
OUTLOOK_MAIL_SCHEME=tls
OUTLOOK_MAIL_USERNAME=null
OUTLOOK_MAIL_PASSWORD=null
OUTLOOK_MAIL_TIMEOUT=30
OUTLOOK_MAIL_AUTH_MODE=smtp_oauth
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_MAILBOX=
OUTLOOK_GRAPH_SAVE_TO_SENT_ITEMS=true
OUTLOOK_GRAPH_TIMEOUT=30

# SECURITY: Azure AD credentials — keep secret, rotate if compromised
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# SECURITY: Never commit the real client secret; rotate periodically via Azure portal
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI="${APP_URL}/auth/azure/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Upload limits ─────────────────────────────────────────────────────────────
# SECURITY: Adjust to the minimum size your workflows require
UPLOAD_PROPOSAL_MAX_BYTES=20971520
UPLOAD_ADMIN_RESPONSE_MAX_KB=102400
UPLOAD_DOCUMENT_MAX_KB=102400
UPLOAD_SUBMISSION_MAX_KB=51200
UPLOAD_SUBMISSION_TOTAL_MAX_BYTES=52428800
UPLOAD_RESUME_MAX_KB=10240
LIVEWIRE_TEMPORARY_UPLOAD_MAX_KB=102400
LIVEWIRE_TEMPORARY_MAX_UPLOAD_TIME=15

# ── ClamAV malware scanning ───────────────────────────────────────────────────
# SECURITY: Enable in production alongside a running clamd daemon
CLAMAV_ENABLED=false
# CLAMAV_SOCKET=/var/run/clamav/clamd.ctl
# CLAMAV_HOST=127.0.0.1
# CLAMAV_PORT=3310
