# ============================================================
# .env.example.production — Template Seguro para Produção
# 
# IMPORTANTE:
# - Cópia segura contendo apenas as as chaves (sem os valores sensíveis)
# - NUNCA comite um arquivo .env real com dados de produção.
# - Use GitHub Secrets / Azure Key Vault para injetar estes valores.
# ============================================================

APP_NAME="BSI Capital"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://SEU_DOMINIO.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ============================================================
# Logging — Info (apenas os mais importantes)
# ============================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ============================================================
# Banco de Dados (Managed Service ou Externa)
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bsicapital_prod
DB_USERNAME=admin_bsicapital
DB_PASSWORD=

# ============================================================
# Configurações de Estado / Cache (Obrigatório: Redis)
# ============================================================
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================
# Segurança Reforçada (Sessão & Cookies)
# ============================================================
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=SEU_DOMINIO.com.br
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ============================================================
# Storage Remoto (Azure Blob / AWS S3)
# ============================================================
FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=sa-east-1
# AWS_BUCKET=bsi-capital-docs
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================
# Mail — Configuração do provedor real (SendGrid, AWS SES)
# ============================================================
MAIL_MAILER=log
MAIL_SCHEME=tls
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TIMEOUT=30
MAIL_FROM_ADDRESS="contato@bsicapital.com.br"
MAIL_FROM_NAME="${APP_NAME}"

PROPOSAL_MAILER=proposal_outlook_failover
PROPOSAL_MAIL_FROM_ADDRESS="contato@bsicapital.com.br"
PROPOSAL_MAIL_FROM_NAME="${APP_NAME}"
PROPOSAL_CONTINUATION_EXPIRES_DAYS=7
PROPOSAL_CONTINUATION_CODE_LENGTH=6

OUTLOOK_MAIL_HOST=smtp.office365.com
OUTLOOK_MAIL_PORT=587
OUTLOOK_MAIL_SCHEME=tls
OUTLOOK_MAIL_USERNAME=
OUTLOOK_MAIL_PASSWORD=
OUTLOOK_MAIL_TIMEOUT=30
OUTLOOK_MAIL_AUTH_MODE=smtp_oauth
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_MAILBOX=

VITE_APP_NAME="${APP_NAME}"
